# Salin ke backend/.env dan isi INFLUX_TOKEN (sama dengan root .env / bridge jika dipakai bersama).
# Docker Compose service `backend` memuat file ini (lihat docker-compose.yml).
# INFLUX_URL di bawah untuk uvicorn lokal; di Docker di-override ke http://influxdb:8086.

INFLUX_URL=http://127.0.0.1:8086
INFLUX_TOKEN=
INFLUX_ORG=S2_Project
INFLUX_BUCKET=tilapia_monitoring
INFLUX_MEASUREMENT=tilapia

CORS_ORIGINS=http://localhost:5173,http://localhost:8081,http://127.0.0.1:5173,http://127.0.0.1:8081
