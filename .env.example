# Salin file ini menjadi .env lalu isi INFLUX_TOKEN (token tidak boleh di-commit).
# PowerShell: Copy-Item .env.example .env

INFLUX_URL=http://127.0.0.1:8086
INFLUX_TOKEN=
INFLUX_ORG=S2_Project
INFLUX_BUCKET=tilapia_monitoring
INFLUX_MEASUREMENT=tilapia

MQTT_HOST=192.168.43.130
MQTT_PORT=1883
MQTT_TOPIC=s2/water/monitoring
# Opsional: ID tetap; default = random per jalan agar tidak bentrok (hindari rc=7 loop)
# MQTT_CLIENT_ID=bridge_s2_satu
# MQTT_KEEPALIVE=120
